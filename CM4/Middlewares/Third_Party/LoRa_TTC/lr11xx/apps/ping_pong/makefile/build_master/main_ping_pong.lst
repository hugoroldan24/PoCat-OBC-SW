 294:../main_ping_pong.c **** 
 295:../main_ping_pong.c **** // Function to handle reception failure
 296:../main_ping_pong.c **** /**
 297:../main_ping_pong.c ****  * @brief Handles the reception failure scenario.
 298:../main_ping_pong.c ****  *
 299:../main_ping_pong.c ****  * This function is called when a reception failure occurs. It performs the necessary
 300:../main_ping_pong.c ****  * actions to handle the failure, including retransmission and setting up the receiver
 301:../main_ping_pong.c ****  * for the next attempt.
 302:../main_ping_pong.c ****  *
 303:../main_ping_pong.c ****  * The function performs the following steps:
 304:../main_ping_pong.c ****  * 1. Calls `apps_common_lr11xx_handle_post_rx` to handle post-reception tasks.
 305:../main_ping_pong.c ****  * 2. Checks if data is available and if the current index is less than the size of the large messa
 306:../main_ping_pong.c ****  *    - If true, it requests transmission to the destination address.
 307:../main_ping_pong.c ****  *    - Otherwise, it prepares for the next reception by calling `apps_common_lr11xx_handle_pre_rx`
 308:../main_ping_pong.c ****  *      setting the receiver with a timeout.
 309:../main_ping_pong.c ****  * 3. If data is not available and the receiver is not in receive mode:
 310:../main_ping_pong.c ****  *    - Logs a retransmission message.
 311:../main_ping_pong.c ****  *    - If the current index is less than the size of the large message, it calculates the transmis
 312:../main_ping_pong.c ****  *      and calls `info_tx` to transmit the data.
 313:../main_ping_pong.c ****  *    - Otherwise, it calls `end_of_tx` to signal the end of transmission.
 314:../main_ping_pong.c ****  * 4. If the receiver is in receive mode:
 315:../main_ping_pong.c ****  *    - Checks if the received frame type is 0x02 (ACK confirmation lost).
 316:../main_ping_pong.c ****  *      - If true, logs a message and calls `end_of_tx` to retransmit the end of transmission.
 317:../main_ping_pong.c ****  *    - Prepares for the next reception by calling `apps_common_lr11xx_handle_pre_rx` and setting t
 318:../main_ping_pong.c ****  *      with a timeout.
 319:../main_ping_pong.c ****  */
 320:../main_ping_pong.c **** static void reception_failure_handling( void )
 321:../main_ping_pong.c **** {
 1123              		.loc 1 321 1
